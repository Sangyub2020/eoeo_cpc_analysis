# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets (never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Shared passcode gate (legacy fallback). Set to any string (e.g. a long random
# word). Leave blank to disable. Google Auth (below) is the primary path; this
# stays for backward compat / emergency access.
APP_PASSCODE=

# Google Auth allowlist — comma-separated emails. Leave blank to allow every
# signed-in Google account (rely on Supabase's OAuth client config to limit
# the audience instead). Example:
#   ALLOWED_EMAILS=ksy@egongegong.com,co-worker@example.com
ALLOWED_EMAILS=
