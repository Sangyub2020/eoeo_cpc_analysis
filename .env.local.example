# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets (never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Google Auth allowlist — comma-separated. Each entry is one of:
#   - Full email:  ksy@egongegong.com
#   - Domain:      @egongegong.com  (or just  egongegong.com )
# Empty = allow every signed-in Google account. Example:
#   ALLOWED_EMAILS=@egongegong.com
#   ALLOWED_EMAILS=ksy@egongegong.com,@example.com
ALLOWED_EMAILS=

# Public base URL for OAuth redirectTo. Set this PER ENVIRONMENT so a
# localhost dev session never bounces to production after Google sign-in:
#   .env.local       NEXT_PUBLIC_SITE_URL=http://localhost:3000
#   Railway / prod   NEXT_PUBLIC_SITE_URL=https://your-app.up.railway.app
# Falls back to window.location.origin when unset (browser only).
NEXT_PUBLIC_SITE_URL=

# Comma-separated list of emails authorized for site-wide moderator actions
# (e.g. changing any feedback post's status). Empty = only ksy@egongegong.com.
NEXT_PUBLIC_ADMIN_EMAILS=

# Gemini (Google AI Studio) — used by the brand dashboard's AI 분석 panel.
# Get a key at https://aistudio.google.com/apikey
# GEMINI_MODEL is optional; defaults to gemini-3.1-pro-preview.
# 자동 폴백은 없음 — 503/429 시 같은 모델로 5번 지수 백오프 재시도.
# 그래도 막히면 다른 모델 ID 로 직접 변경해야 함.
GEMINI_API_KEY=
GEMINI_MODEL=
